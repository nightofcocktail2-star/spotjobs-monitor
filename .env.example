# Firebase リフレッシュトークン
# 取得方法: Chrome DevTools > Application > IndexedDB > firebaseLocalStorageDb
#           > firebaseLocalStorage > value > stsTokenManager > refreshToken
FIREBASE_REFRESH_TOKEN=AMf-vBx...（長い文字列）

# Gmail 通知設定
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx
MAIL_TO=notify-to@example.com
