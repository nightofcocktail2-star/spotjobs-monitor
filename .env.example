# SPOT.JOBS ログイン情報
SPOT_EMAIL=your-spotjobs-email@example.com
SPOT_PASS=your-spotjobs-password

# Gmail 通知設定
# MAIL_USER: 送信元Gmailアドレス
# MAIL_PASS: Gmailのアプリパスワード（16文字）※通常のパスワードではない
#   取得方法: Googleアカウント > セキュリティ > 2段階認証を有効化 > アプリパスワード
# MAIL_TO:   通知先メールアドレス（自分のアドレスでOK）
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx
MAIL_TO=notify-to@example.com
